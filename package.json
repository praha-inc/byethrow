{
  "name": "byethrow",
  "private": true,
  "scripts": {
    "generate": "turbo generate",
    "build": "turbo build",
    "test": "turbo test",
    "lint:code": "turbo lint:code",
    "lint:type": "turbo lint:type",
    "version": "changeset",
    "version:apply": "changeset version",
    "version:publish": "changeset publish",
    "version:prepublish": "pkg-pr-new publish --pnpm --compact './packages/*'"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@praha/oxlint-config-standard": "1.0.0-beta.5",
    "@tsconfig/strictest": "2.0.8",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "pkg-pr-new": "0.0.66",
    "turbo": "2.9.6",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "rspress-plugin-og>@rspress/shared": "-",
      "rspress-plugin-og>rspress": "-"
    },
    "packageExtensions": {
      "rspress-plugin-og": {
        "dependencies": {
          "rslog": "^2.0.0"
        }
      }
    },
    "patchedDependencies": {
      "@changesets/assemble-release-plan": "patches/@changesets__assemble-release-plan.patch",
      "rspress-plugin-og": "patches/rspress-plugin-og.patch"
    }
  }
}
