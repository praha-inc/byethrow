{
  "name": "@praha/byethrow-testing",
  "version": "0.11.1",
  "description": "Custom test matchers for asserting @praha/byethrow Result types.",
  "keywords": [
    "javascript",
    "typescript",
    "throw",
    "error",
    "functional",
    "test"
  ],
  "homepage": "https://praha-inc.github.io/byethrow",
  "bugs": {
    "url": "https://github.com/praha-inc/byethrow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praha-inc/byethrow.git",
    "directory": "packages/byethrow-testing"
  },
  "license": "MIT",
  "author": "PrAha, Inc.",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "require": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    },
    "import": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rslib build",
    "build:doc": "typedoc",
    "test": "vitest run",
    "test:watch": "vitest watch --typecheck",
    "lint:code": "oxlint",
    "lint:type": "tsc --noEmit"
  },
  "devDependencies": {
    "@praha/byethrow": "workspace:*",
    "@rslib/core": "0.21.0",
    "oxlint": "1.59.0",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "@praha/byethrow": "workspace:*"
  },
  "publishConfig": {
    "provenance": true
  }
}
